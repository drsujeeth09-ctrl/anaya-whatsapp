{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/send-booking-link.js":      { "maxDuration": 15 },
    "api/send-prescription.js":      { "maxDuration": 15 },
    "api/send-receipt.js":           { "maxDuration": 15 },
    "api/run-daily-reminders.js":    { "maxDuration": 60 },
    "api/whatsapp-webhook.js":       { "maxDuration": 30 },
    "api/inbound-webhook.js":        { "maxDuration": 15 },
    "api/publish-daily-reel.js":     { "maxDuration": 300, "includeFiles": "data/**" },
    "api/publish-ig-reel.js":        { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/run-daily-reminders",
      "schedule": "30 3 * * *"
    }
  ]
}
